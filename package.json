{
  "name": "openclaw-skill-curator",
  "version": "0.3.2",
  "description": "Observe successful OpenClaw turns and surface repeatable workflow candidates for Skill Workshop review.",
  "private": false,
  "type": "module",
  "license": "MIT",
  "author": "Jean-Christophe Laplace",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/creanet-64/openclaw-skill-curator.git"
  },
  "bugs": {
    "url": "https://github.com/creanet-64/openclaw-skill-curator/issues"
  },
  "homepage": "https://github.com/creanet-64/openclaw-skill-curator#readme",
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "skills",
    "workflow",
    "automation"
  ],
  "files": [
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "SECURITY.md",
    "docs",
    "index.js",
    "lib",
    "openclaw.plugin.json",
    "package.json"
  ],
  "openclaw": {
    "extensions": [
      "./index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.6.6",
      "minGatewayVersion": ">=2026.6.6"
    },
    "build": {
      "openclawVersion": "2026.6.9"
    }
  },
  "scripts": {
    "test": "node --test test/*.test.js"
  }
}
